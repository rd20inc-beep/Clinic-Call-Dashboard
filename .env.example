# ============================================
# Clinicea Call Dashboard — Environment Config
# ============================================
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ---- Server ----
# Port the Express server listens on
PORT=3000

# Set to 1 when behind a reverse proxy (nginx, Cloudflare, etc.)
TRUST_PROXY=1

# ---- Doctor phone (for reference / display) ----
DOCTOR_PHONE=+92XXXXXXXXXX

# ---- Clinicea web app (patient lookup links) ----
CLINICEA_BASE_URL=https://app.clinicea.com/clinic.aspx

# ---- Clinicea API credentials ----
CLINICEA_API_KEY=your_api_key_here
CLINICEA_API_BASE=https://api.clinicea.com
CLINICEA_STAFF_USERNAME=your_staff_username_here
CLINICEA_STAFF_PASSWORD=your_staff_password_here

# ---- Session secret ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate_a_random_64_char_hex_string

# ---- Webhook secret for monitor→server auth ----
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
WEBHOOK_SECRET=generate_a_random_48_char_hex_string

# ---- Groq API key (for WhatsApp AI chatbot) ----
GROQ_API_KEY=

# ---- WhatsApp Chrome extension secret ----
EXTENSION_SECRET=

# ---- CORS allowed origins (comma-separated, for Chrome extensions) ----
# Example: chrome-extension://abcdefghijklmnop
ALLOWED_CORS_ORIGINS=

# ---- User credentials (bcrypt hashes) ----
# Generate hash: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))"
#
# Migration mode: if _HASH vars are not set, you can use _PASS vars with plaintext
# passwords (a warning will be logged). Migrate to hashes ASAP.
#
USER_ADMIN_HASH=
USER_AGENT1_HASH=
USER_AGENT2_HASH=
USER_AGENT3_HASH=
USER_AGENT4_HASH=
USER_AGENT5_HASH=

# Plaintext fallback (migration only — set hashes above instead)
# USER_ADMIN_PASS=
# USER_AGENT1_PASS=
# USER_AGENT2_PASS=
# USER_AGENT3_PASS=
# USER_AGENT4_PASS=
# USER_AGENT5_PASS=
